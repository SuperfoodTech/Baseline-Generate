# Kredensial Bot Discord Baru Anda
DISCORD_TOKEN=your_discord_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here

# URL Webhook Discord untuk pengiriman notifikasi status sesi
WEBHOOK_URL=your_webhook_url_here

# URL Google Apps Script jika dibutuhkan oleh VB pipeline
VB_APPS_SCRIPT_URL=your_apps_script_url_here

# Konfigurasi Headless (set false agar browser terbuka secara visual)
HEADLESS=true
