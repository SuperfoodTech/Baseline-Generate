# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── uv ─────────────────────────────────────────────────────────────────────
# Keep uv.lock committed (reproducible installs), ignore cache
.uv/

# ── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
token.json
service_account*.json

# ── Playwright / Browser Automation ────────────────────────────────────────
browser_data/
sessions/
playwright-report/
test-results/
*.trace
*.webm
*.zip            # Playwright traces

# ── Screenshot / Debug images ──────────────────────────────────────────────
*.png
*.jpg
*.jpeg
!docs/**/*.png   # allow docs screenshots

# ── Downloads & Raw Data ───────────────────────────────────────────────────
downloads/
backups/
scratch/

src/config.json

# ── Reports & Output (generated files) ─────────────────────────────────────
laporan/
data/reports/
*.csv
*.xlsx
*.xls

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE & Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Python version file (keep for reference) ───────────────────────────────
# ── Shopee Specific ────────────────────────────────────────────────────────
**/shopee-omzet-automation/data/**
**/shopee-omzet-automation/logs/
**/shopee-omzet-automation/API/*.json

# ── Node & Env ─────────────────────────────────────────────────────────────
node_modules/
**/.env
**/baseline/*/data/**

# ── GoFood / Temp Files ────────────────────────────────────────────────────
src/gofood-automation/
/cli.py


# ── Chrome Profiles ────────────────────────────────────────────────────────
**/chrome_profiles/
**/chrome_profile/
**/chrome_profile_*/
**/chrome_profile_*

# ── Session Exceptions ──────────────────────────────────────────────────────
# Note: We now ignore all session files so that git pull on laptops does not 
# overwrite or restart sessions. All sessions should be local to the machine.
**/sessions/
**/session*.json
**/data/session.json

# Allow Shopee baseline session for server
!.env.example
!src/baseline/shopee/data/
!src/baseline/shopee/data/session.json
!src/VB/shopee/sessions/
!src/VB/shopee/sessions/*.json

!src/shopee-omzet-automation/data/chrome_profile_auto7303/
!src/shopee-omzet-automation/data/chrome_profile_auto7303/**
!src/shopee-omzet-automation/data/session_auto7303.json
!src/shopee-omzet-automation/data/chrome_profile_auto7304_/
!src/shopee-omzet-automation/data/chrome_profile_auto7304_/**
!src/shopee-omzet-automation/data/session_auto7304_.json
!src/shopee-omzet-automation/data/chrome_profile_auto7307/
!src/shopee-omzet-automation/data/chrome_profile_auto7307/**
!src/shopee-omzet-automation/data/session_auto7307.json
!src/shopee-omzet-automation/data/chrome_profile_auto7308/
!src/shopee-omzet-automation/data/chrome_profile_auto7308/**
!src/shopee-omzet-automation/data/session_auto7308.json
!src/shopee-omzet-automation/data/chrome_profile_auto7309/
!src/shopee-omzet-automation/data/chrome_profile_auto7309/**
!src/shopee-omzet-automation/data/session_auto7309.json
!src/shopee-omzet-automation/data/chrome_profile_auto7310/
!src/shopee-omzet-automation/data/chrome_profile_auto7310/**
!src/shopee-omzet-automation/data/session_auto7310.json
!src/shopee-omzet-automation/data/chrome_profile_auto7311/
