# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual Environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.bak

# ── uv ─────────────────────────────────────────────────────────────────────
# Keep uv.lock committed (reproducible installs), ignore cache
.uv/

# ── Environment & Secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
token.json
service_account*.json

# ── Playwright / Browser Automation ────────────────────────────────────────
browser_data/
sessions/
playwright-report/
test-results/
*.trace
*.webm
*.zip            # Playwright traces

# ── Screenshot / Debug images ──────────────────────────────────────────────
*.png
*.jpg
*.jpeg
!docs/**/*.png   # allow docs screenshots

# ── Downloads & Raw Data ───────────────────────────────────────────────────
downloads/
backups/
scratch/

src/config.json

# ── Reports & Output (generated files) ─────────────────────────────────────
laporan/
data/reports/
*.csv
*.xlsx
*.xls

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE & Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Python version file (keep for reference) ───────────────────────────────
# ── Shopee Specific ────────────────────────────────────────────────────────
**/shopee-omzet-automation/data/**
**/shopee-omzet-automation/logs/
**/shopee-omzet-automation/API/*.json

# ── Node & Env ─────────────────────────────────────────────────────────────
node_modules/
**/.env
**/baseline/*/data/**

# ── GoFood / Temp Files ────────────────────────────────────────────────────
src/gofood-automation/
cli.py

# ── Chrome Profiles ────────────────────────────────────────────────────────
**/chrome_profiles/
**/chrome_profile/
**/chrome_profile_*/
**/chrome_profile_*

# ── Session Exceptions ──────────────────────────────────────────────────────
# Note: We now ignore all session files so that git pull on laptops does not 
# overwrite or restart sessions. All sessions should be local to the machine.
**/sessions/
**/session*.json
**/data/session.json

# Allow Shopee baseline session for server
!.env.example
!src/baseline/shopee/data/
!src/baseline/shopee/data/session.json
!src/shopee-omzet-automation/data/session*.json
!src/VB/shopee/sessions/
!src/VB/shopee/sessions/*.json

# Whitelist specific Shopee profiles for session persistence
!src/shopee-omzet-automation/data/chrome_profile_auto73*/
!src/shopee-omzet-automation/data/chrome_profile_auto73*/**

# Exclude bloat, cache, history, and lock files from the whitelisted profiles
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Cache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Code Cache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/GPUCache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/DawnGraphiteCache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/DawnWebGPUCache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/ShaderCache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/GrShaderCache/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/BrowserMetrics/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/locks/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/lock
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/*Lock*
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/LOCK
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/LOG
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/LOG.old
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/History*
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Favicons*
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Top Sites*
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Shortcuts*
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Download Service/
src/shopee-omzet-automation/data/chrome_profile_auto73*/**/Safe Browsing*


