# ── Discord Bot – Configuration Template ──────────────────────────────────────
# Salin file ini ke .env dan isi nilainya sebelum menjalankan Docker.
# cp discord-bot-form/.env.example discord-bot-form/.env

# =============================================================================
# [WAJIB] Discord Bot
# =============================================================================

# Token Bot Discord — dapatkan di https://discord.com/developers/applications
DISCORD_TOKEN=

# Application ID Bot Discord (bukan token, tapi ID angka)
CLIENT_ID=

# ID Server (Guild) Discord tempat bot beroperasi
GUILD_ID=

# =============================================================================
# [WAJIB] Database PostgreSQL
# Sesuaikan dengan konfigurasi di docker-compose.yml.
# Jika menggunakan nilai default docker-compose, biarkan apa adanya.
# =============================================================================

DB_HOST=db
DB_PORT=5432
DB_USER=superfood_admin
DB_PASS=superfood_password
DB_NAME=srs_db

# =============================================================================
# [WAJIB] Google Apps Script Webhook
# URL Web App yang di-deploy dari appscriptOFD/ untuk generate PDF Baseline.
# =============================================================================

WEBHOOK_URL=https://script.google.com/macros/s/XXXXXX/exec

# =============================================================================
# [OPSIONAL] Konfigurasi Runtime
# =============================================================================

# Timezone container (default: Asia/Jakarta)
TZ=Asia/Jakarta
