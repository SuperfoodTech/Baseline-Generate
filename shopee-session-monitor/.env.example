# ── Shopee Session Monitor / Warmer – Configuration Template ──────────────────
# Copy this file to .env and adjust the values as needed.

# Set to false when testing locally so you can see the browser GUI.
# Set to true on the server so Chrome runs in the background.
HEADLESS=false

# Seconds to wait between each full cycle (all accounts processed once).
# Default: 1800 = 30 minutes
LOOP_DELAY_SECONDS=1800

# Seconds to wait between processing each individual account.
# Default: 15 seconds
ACCOUNT_DELAY_SECONDS=15

# Comma-separated list of account usernames to warm.
# Must match the entries in the Google Sheets credentials.
ACCOUNTS=auto7303,auto7304_,auto7307,auto7308,auto7309,auto7310,auto7311,auto7312,auto7313

# (Optional) Discord webhook URL to receive notifications.
# Leave blank to disable Discord notifications.


# Push Monitor Uptime Kuma
UPTIME_KUMA_PUSH_URL=""
